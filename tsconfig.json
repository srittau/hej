{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["dom", "dom.iterable", "es2024"],
    "types": ["vite/client", "vitest/globals"],
    "allowJs": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": true
  }
}
